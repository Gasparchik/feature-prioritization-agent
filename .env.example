# Anthropic API key — required for clustering, PRD and summary generation.
ANTHROPIC_API_KEY=sk-ant-...

# Comma-separated list of origins allowed by CORS.
# In production set this to the public URL of the frontend, e.g.:
#   ALLOWED_ORIGINS=https://features.example.com
# Defaults to http://localhost:5173,http://localhost:3000 for local dev.
ALLOWED_ORIGINS=http://localhost

# When set, the backend trusts the X-Forwarded-For header for client IP
# detection (rate limiting). Only enable when running behind a reverse
# proxy you control (nginx, Cloudflare, etc.).
TRUST_PROXY=1

# Redis connection string for persistent rate-limit storage. If unset,
# slowapi falls back to in-memory limits (lost on restart).
REDIS_URL=redis://redis:6379

# Optional: override where the session cache is written. Useful in Docker
# so the file lives on a mounted volume.
SESSION_CACHE_PATH=/data/.session_cache.json

# Optional: host port the frontend nginx binds to (default 80).
FRONTEND_PORT=80
